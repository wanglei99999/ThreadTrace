{
  "version": "1.0",
  "name": "rss-archive-normalized-feed-rollout",
  "source": {
    "sourceKey": "rss-archive",
    "sourceType": "rss-archive-normalized-feed",
    "displayName": "RSS/API archive normalized feed",
    "location": {
      "inputFile": "docs/examples/external-thread.sample.json",
      "feedUrl": "https://example.test/rss.xml",
      "archiveLabel": "example-rss-archive"
    },
    "tags": ["rss", "api", "archive", "normalized-json"]
  },
  "connector": {
    "modulePath": "docs/examples/rss-archive-connector-package/index.cjs"
  },
  "ingest": {
    "dryRun": true,
    "allowRemoteFetch": false
  },
  "workers": {
    "topology": "operations-worker",
    "sourceTaskMode": "ingest"
  },
  "deployment": {
    "storeDir": "data/store",
    "limit": 100
  }
}
