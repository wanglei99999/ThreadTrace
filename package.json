{
  "name": "threadtrace",
  "version": "0.1.0",
  "private": true,
  "description": "语脉 ThreadTrace: forum opinion context tracing and evidence analysis.",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "parse:sample": "node src/presentation/cli/threadtrace.js parse-html",
    "analyze:sample": "node src/presentation/cli/threadtrace.js analyze-html",
    "analyze:sample-dir": "node src/presentation/cli/threadtrace.js analyze-html-dir",
    "ingest:sample-dir": "node src/presentation/cli/threadtrace.js ingest-html-dir",
    "task:ingest:sample": "node src/presentation/cli/threadtrace.js run-ingest-task",
    "index:sample-dir": "node src/presentation/cli/threadtrace.js index-html-dir",
    "search:sample": "node src/presentation/cli/threadtrace.js search-index --text 科技",
    "interpret:sample": "node src/presentation/cli/threadtrace.js interpret-text-dir --text 科技后面看量确认",
    "serve": "node src/presentation/http/server.js",
    "serve:web": "node src/presentation/http/server.js",
    "worker:due-once": "node src/presentation/worker/dueSourceWorkerMain.js --once",
    "worker:due-loop": "node src/presentation/worker/dueSourceWorkerMain.js --loop",
    "worker:events-once": "node src/presentation/worker/notificationEventWorkerMain.js --once",
    "worker:events-loop": "node src/presentation/worker/notificationEventWorkerMain.js --loop",
    "worker:operations-once": "node src/presentation/worker/operationsWorkerMain.js --once",
    "worker:operations-loop": "node src/presentation/worker/operationsWorkerMain.js --loop",
    "diagnostics:runtime": "node src/presentation/cli/threadtrace.js runtime-diagnostics",
    "diagnostics:adapters": "node src/presentation/cli/threadtrace.js adapter-diagnostics",
    "diagnostics:sources": "node src/presentation/cli/threadtrace.js source-diagnostics",
    "diagnostics:notifications": "node src/presentation/cli/threadtrace.js notification-diagnostics",
    "connectors:catalog": "node src/presentation/cli/threadtrace.js connector-catalog",
    "source:validate:sample": "node src/presentation/cli/threadtrace.js validate-source --forum nga --source-type saved-html-directory --input example",
    "source:dry-run:sample": "node src/presentation/cli/threadtrace.js source-ingest-dry-run --forum nga --source-type saved-html-directory --input example",
    "deployment:checklist": "node src/presentation/cli/threadtrace.js deployment-checklist",
    "deployment:gate": "node src/presentation/cli/threadtrace.js deployment-gate",
    "operations:trace-context": "node src/presentation/cli/threadtrace.js trace-context",
    "operations:worker-topology-plan": "node src/presentation/cli/threadtrace.js worker-topology-plan",
    "operations:runbook": "node src/presentation/cli/threadtrace.js operations-runbook",
    "operations:synthesize-runbook-events": "node src/presentation/cli/threadtrace.js synthesize-runbook-events",
    "operations:list-events": "node src/presentation/cli/threadtrace.js list-events",
    "operations:events-overview": "node src/presentation/cli/threadtrace.js events-overview",
    "operations:dispatch-events": "node src/presentation/cli/threadtrace.js dispatch-events",
    "operations:ack-events": "node src/presentation/cli/threadtrace.js ack-events --dry-run true",
    "operations:archive-events": "node src/presentation/cli/threadtrace.js archive-events",
    "operations:resource-provisioning-plan": "node src/presentation/cli/threadtrace.js resource-provisioning-plan",
    "operations:rollout-manifest-apply": "node src/presentation/cli/threadtrace.js rollout-manifest-apply --manifest-file docs/examples/rollout-manifest.sample.json",
    "test:unit": "node --test test"
  }
}
