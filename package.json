{
  "name": "threadtrace",
  "version": "0.1.0",
  "private": true,
  "description": "语脉 ThreadTrace: forum opinion context tracing and evidence analysis.",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "parse:sample": "node src/presentation/cli/threadtrace.js parse-html",
    "analyze:sample": "node src/presentation/cli/threadtrace.js analyze-html",
    "analyze:sample-dir": "node src/presentation/cli/threadtrace.js analyze-html-dir",
    "ingest:sample-dir": "node src/presentation/cli/threadtrace.js ingest-html-dir",
    "task:ingest:sample": "node src/presentation/cli/threadtrace.js run-ingest-task",
    "index:sample-dir": "node src/presentation/cli/threadtrace.js index-html-dir",
    "search:sample": "node src/presentation/cli/threadtrace.js search-index --text 科技",
    "interpret:sample": "node src/presentation/cli/threadtrace.js interpret-text-dir --text 科技后面看量确认",
    "serve": "node src/presentation/http/server.js",
    "serve:web": "node src/presentation/http/server.js",
    "worker:due-once": "node src/presentation/worker/dueSourceWorkerMain.js --once",
    "worker:due-loop": "node src/presentation/worker/dueSourceWorkerMain.js --loop",
    "test:unit": "node --test test"
  }
}
