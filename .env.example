THREADTRACE_STORAGE=file
THREADTRACE_STORE_DIR=data/store
THREADTRACE_DEFAULT_FORUM=nga
THREADTRACE_EXAMPLE_DIR=example
THREADTRACE_HTTP_HOST=127.0.0.1
THREADTRACE_HTTP_PORT=3017

# PostgreSQL storage mode:
# THREADTRACE_STORAGE=postgres
# THREADTRACE_DATABASE_URL=postgres://threadtrace:threadtrace@127.0.0.1:5432/threadtrace
# THREADTRACE_POSTGRES_POOL_MAX=10
# THREADTRACE_POSTGRES_SSL=disable

# Notification workers:
# THREADTRACE_WEBHOOK_URL=http://127.0.0.1:9000/threadtrace-events
# THREADTRACE_EVENT_WORKER_INTERVAL_MS=60000
# THREADTRACE_WORKER_INTERVAL_MS=300000
# THREADTRACE_OPERATIONS_WORKER_INTERVAL_MS=60000
# THREADTRACE_WORKER_LEASE_TTL_MS=300000
# THREADTRACE_SOURCE_TASK_MODE=ingest
# THREADTRACE_SOURCE_TASK_MODE=insight-pipeline

# LLM enrichment:
# THREADTRACE_LLM_PROVIDER=mock
# THREADTRACE_LLM_PROVIDER=openai-compatible
# THREADTRACE_LLM_BASE_URL=https://api.openai.com
# THREADTRACE_LLM_API_KEY=
# THREADTRACE_LLM_MODEL=
# THREADTRACE_LLM_TIMEOUT_MS=30000
